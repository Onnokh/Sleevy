# Postgres
POSTGRES_PASSWORD=change-me

# Better Auth
BETTER_AUTH_SECRET=replace-with-32-char-random-string
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_APP_BUNDLE_IDENTIFIER=app.sleevy

# Public URLs (Coolify sets SERVICE_URL_* automatically from each service's
# configured domain; override locally if needed)
SERVICE_URL_API=http://localhost:3002
SERVICE_URL_WEB=http://localhost:8080

# AI (optional)
AI_ENABLED=false
AI_PROVIDER=
AI_MODEL=

# Analytics (Rybbit, optional, server-side only)
# RYBBIT_API_URL and RYBBIT_SITE_ID are non-secret. Set RYBBIT_API_KEY only in
# real environments (Coolify secrets / local .env) — never commit a real key.
RYBBIT_ENABLED=false
RYBBIT_API_URL=https://rybbit.missingmounts.com
RYBBIT_SITE_ID=c8631725ed4a
RYBBIT_API_KEY=
