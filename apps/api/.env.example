DATABASE_URL=postgres://sleevy:sleevy@localhost:5434/sleevy
PORT=3002

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_APP_BUNDLE_IDENTIFIER=app.sleevy
BETTER_AUTH_SECRET=
# Google OAuth accepts localhost redirects, but rejects .localhost subdomains.
# When running `pnpm --filter @sleevy/api dev`, portless exposes the API on
# https://api.sleevy.localhost while the Bun app listens on localhost:4001.
BETTER_AUTH_URL=http://localhost:4001
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:4000,http://127.0.0.1:4000,https://web.sleevy.localhost,https://sleevy.app,https://api.sleevy.app,https://appleid.apple.com

AI_ENABLED=false
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-nano
OPENAI_API_KEY=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
