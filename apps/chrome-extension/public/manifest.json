{
  "manifest_version": 3,
  "name": "Sleevy",
  "description": "Save the current tab to your Sleevy read-later list with one click.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Save to Sleevy"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "alarms", "identity", "storage"],
  "host_permissions": ["https://api.sleevy.app/*", "https://sleevy.app/*"]
}